//Code for Arduino Nano ButtonLight

int BUTTON_PIN = 2;
int LED_PIN = 3;

int buttonState = 0;


void setup() {
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(LED_PIN, OUTPUT);
}
  
void loop() {
  buttonState = digitalRead(BUTTON_PIN);
  
  if (buttonState == LOW) {
    digitalWrite(LED_PIN, LOW);
  }
  else {
    digitalWrite(LED_PIN, HIGH);
  }
}

